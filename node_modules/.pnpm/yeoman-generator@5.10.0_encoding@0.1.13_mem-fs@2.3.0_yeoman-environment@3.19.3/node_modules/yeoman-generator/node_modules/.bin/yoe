#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/a-/ITMO Fall 2025/MSE_Diploma/node_modules/.pnpm/yeoman-environment@3.19.3/node_modules/yeoman-environment/node_modules:/Users/a-/ITMO Fall 2025/MSE_Diploma/node_modules/.pnpm/yeoman-environment@3.19.3/node_modules:/Users/a-/ITMO Fall 2025/MSE_Diploma/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/a-/ITMO Fall 2025/MSE_Diploma/node_modules/.pnpm/yeoman-environment@3.19.3/node_modules/yeoman-environment/node_modules:/Users/a-/ITMO Fall 2025/MSE_Diploma/node_modules/.pnpm/yeoman-environment@3.19.3/node_modules:/Users/a-/ITMO Fall 2025/MSE_Diploma/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../yeoman-environment/cli/index.js" "$@"
else
  exec node  "$basedir/../../../yeoman-environment/cli/index.js" "$@"
fi
